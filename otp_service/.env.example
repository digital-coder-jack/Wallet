# ─────────────────────────────────────────────────────────────────────────────
# NexWallet OTP Service — Environment Variables Template
# Copy to .env and fill in your credentials:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# 1. Enable 2-Step Verification at https://myaccount.google.com/security
# 2. Create an App Password at https://myaccount.google.com/apppasswords
# 3. Paste the 16-char app password as SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password
EMAIL_FROM=NexWallet <your_gmail@gmail.com>

# ── SMS via Twilio ────────────────────────────────────────────────────────────
# Sign up at https://www.twilio.com (free trial gives $15 credit)
# Dashboard → Account Info → Account SID & Auth Token
# Phone Numbers → Buy a Number (or use trial number)
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_auth_token_here
TWILIO_FROM=+1XXXXXXXXXX

# ── Security Keys (change to long random strings!) ────────────────────────────
ADMIN_SECRET=change_this_to_a_long_random_secret_for_admin_api
HMAC_SECRET=change_this_to_another_long_random_secret_for_hmac_signing

# ── OTP Tuning ────────────────────────────────────────────────────────────────
OTP_TTL_SECONDS=600      # 10 minutes
MAX_SEND_TRIES=3         # OTP resends per 10-min window
MAX_VERIFY_TRIES=3       # Wrong attempts before lockout
LOCK_SECONDS=900         # 15-minute lockout duration
