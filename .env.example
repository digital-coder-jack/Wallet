# ─────────────────────────────────────────────────────────
# NexWallet — Environment Variables Example
# ─────────────────────────────────────────────────────────
# Copy this file to .dev.vars for local Cloudflare dev:
#   cp .env.example .dev.vars
#
# For production, set secrets via:
#   wrangler pages secret put SECRET_NAME
# ─────────────────────────────────────────────────────────

# App
APP_NAME=NexWallet
APP_VERSION=2.0.0

# (Optional) Add your own API keys below if you extend the app
# COINGECKO_API_KEY=your_key_here
# ETHERSCAN_API_KEY=your_key_here
