# ════════════════════════════════════════════════════════════════════════════
#  NexWallet OTP Service — Environment Configuration
#  Copy this file to .env and fill in your real credentials.
#  NEVER commit the .env file to version control.
# ════════════════════════════════════════════════════════════════════════════

# ── Email OTP (Gmail recommended) ────────────────────────────────────────────
# Create a Gmail App Password at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16char_app_password
EMAIL_FROM=NexWallet <your_gmail@gmail.com>

# ── SMS OTP via Twilio ────────────────────────────────────────────────────────
# Sign up at: https://www.twilio.com/try-twilio
# Get your SID and auth token from: https://console.twilio.com/
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_auth_token_here
TWILIO_FROM=+1XXXXXXXXXX

# ── Security Secrets ──────────────────────────────────────────────────────────
# Generate strong secrets with: python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_SECRET=change_this_to_a_very_long_random_secret_string
HMAC_SECRET=another_long_random_secret_for_hmac_signing

# ── OTP Settings ──────────────────────────────────────────────────────────────
OTP_TTL_SECONDS=600      # OTP expiry: 10 minutes
MAX_SEND_TRIES=3         # Max OTP resend requests per window
MAX_VERIFY_TRIES=3       # Wrong OTP attempts before account lockout
LOCK_SECONDS=900         # Lockout duration: 15 minutes

# ════════════════════════════════════════════════════════════════════════════
#  NOTES:
#  - If SMTP_USER/SMTP_PASS are not set, OTP is only logged to console (DEV MODE).
#  - If TWILIO_SID/TOKEN/FROM are not set, SMS OTP is only logged to console (DEV MODE).
#  - DEV MODE OTPs are also returned in the API response as "dev_otp" field.
#  - In production, make sure to set all credentials and change secret keys.
# ════════════════════════════════════════════════════════════════════════════
